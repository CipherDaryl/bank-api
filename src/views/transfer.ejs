<%- include('layout', { 
  title: 'Virement',
  user: user,
  message: message
}) %>
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="bi bi-arrow-left-right"></i> Virement</h4>
      </div>
      <div class="card-body">
        <form action="/transfer" method="POST">
          <div class="mb-3">
            <label class="form-label">Compte source *</label>
            <select name="fromAccountId" class="form-select" required>
              <option value="">Sélectionnez...</option>
              <% accounts.forEach(account => { %>
                <option value="<%= account.id %>">
                  <%= account.accountNumber %> - <%= Number(account.balance).toLocaleString() %> <%= account.currency %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Compte destinataire *</label>
            <input type="text" name="toAccountNumber" class="form-control" required placeholder="FR123456789012345678">
          </div>
          <div class="mb-3">
            <label class="form-label">Montant (XAF) *</label>
            <input type="number" name="amount" class="form-control" required placeholder="0" min="1">
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <input type="text" name="description" class="form-control" placeholder="Paiement fournisseur">
          </div>
          <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a href="/dashboard" class="btn btn-secondary">Annuler</a>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-arrow-left-right"></i> Transférer
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>