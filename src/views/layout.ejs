<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Bank System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark:      #0D1117;
            --bg-card:      #161B22;
            --bg-card-hover:#1C2230;
            --primary:      #3B82F6;
            --primary-dark: #2563EB;
            --primary-glow: rgba(59,130,246,0.18);
            --accent:       #60A5FA;
            --text-light:   #E6EDF3;
            --text-muted:   #7D8590;
            --border-color: rgba(255,255,255,0.08);
            --border-em:    rgba(255,255,255,0.14);
            --success:      #3DD68C;
            --success-dim:  rgba(61,214,140,0.14);
            --danger:       #F87171;
            --danger-dim:   rgba(248,113,113,0.14);
            --shadow:       0 8px 32px rgba(0,0,0,0.4);
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--bg-dark);
            color: var(--text-light);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }
        a { text-decoration: none; color: inherit; }

        /* NAVBAR */
        .navbar {
            background: rgba(13,17,23,0.92) !important;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-em) !important;
            padding: 12px 0;
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.35rem;
            letter-spacing: -0.5px;
            color: #fff !important;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .navbar-brand .brand-icon {
            width: 30px;
            height: 30px;
            background: var(--primary);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #fff;
        }
        .navbar-brand span { color: var(--accent); }

        .nav-link {
            color: var(--text-muted) !important;
            font-weight: 500;
            transition: color 0.2s, background 0.2s;
            padding: 7px 14px !important;
            border-radius: 8px;
            font-size: 0.875rem;
        }
        .nav-link:hover {
            color: var(--text-light) !important;
            background: rgba(255,255,255,0.06);
        }
        .nav-link i { margin-right: 6px; }

        .navbar-text {
            color: var(--text-light) !important;
            font-weight: 500;
            font-size: 0.875rem;
        }
        .user-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border-em);
            padding: 4px 12px 4px 6px;
            border-radius: 999px;
        }
        .user-avatar {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--primary-glow);
            border: 1px solid var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: var(--accent);
        }

        /* CARDS */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-color) !important;
            border-radius: 14px !important;
            box-shadow: var(--shadow);
            transition: border-color 0.2s, transform 0.2s;
            overflow: hidden;
        }
        .card:hover {
            transform: translateY(-3px);
            border-color: var(--border-em) !important;
            box-shadow: 0 16px 48px rgba(0,0,0,0.5);
        }
        .card-header {
            background: rgba(255,255,255,0.03);
            color: var(--text-light);
            border-bottom: 1px solid var(--border-color) !important;
            padding: 16px 22px;
            font-weight: 700;
            font-size: 1rem;
        }
        .card-header i { color: var(--accent); margin-right: 8px; }
        .card-body { padding: 24px 22px; }

        /* BUTTONS */
        .btn {
            border-radius: 9px;
            font-weight: 600;
            padding: 10px 22px;
            transition: all 0.2s ease;
            border: none;
            font-size: 0.875rem;
            text-transform: none;
            letter-spacing: 0;
        }
        .btn:hover  { transform: translateY(-1px); }
        .btn:active { transform: translateY(0); }

        .btn-primary {
            background: var(--primary);
            color: #fff;
            box-shadow: 0 2px 12px rgba(59,130,246,0.3);
        }
        .btn-primary:hover {
            background: var(--primary-dark);
            color: #fff;
            box-shadow: 0 4px 20px rgba(59,130,246,0.45);
        }
        .btn-success {
            background: var(--success-dim);
            color: var(--success) !important;
            border: 1px solid rgba(61,214,140,0.25) !important;
        }
        .btn-success:hover {
            background: rgba(61,214,140,0.22);
            color: var(--success) !important;
        }
        .btn-danger {
            background: var(--danger-dim);
            color: var(--danger) !important;
            border: 1px solid rgba(248,113,113,0.25) !important;
        }
        .btn-danger:hover {
            background: rgba(248,113,113,0.22);
            color: var(--danger) !important;
        }
        .btn-outline-primary {
            border: 1px solid var(--primary) !important;
            color: var(--accent);
            background: transparent;
        }
        .btn-outline-primary:hover {
            background: var(--primary-glow);
            color: var(--accent);
            transform: translateY(-1px);
        }

        /* BALANCE */
        .balance {
            font-size: 2.4rem;
            font-weight: 800;
            color: var(--text-light);
            letter-spacing: -1px;
            line-height: 1.15;
        }
        .balance small {
            font-size: 1rem;
            font-weight: 500;
            color: var(--text-muted);
            margin-left: 4px;
        }

        /* BADGES */
        .badge {
            padding: 4px 10px;
            border-radius: 999px;
            font-weight: 600;
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .badge-success { background: var(--success-dim); color: var(--success); }
        .badge-danger  { background: var(--danger-dim);  color: var(--danger); }
        .badge-warning { background: rgba(251,191,36,0.15); color: #FBBF24; }
        .badge-info    { background: var(--primary-glow); color: var(--accent); }

        /* ALERTS */
        .alert {
            border-radius: 10px;
            border: none;
            padding: 14px 18px;
            font-weight: 500;
            font-size: 0.875rem;
        }
        .alert-success {
            background: var(--success-dim);
            color: var(--success);
            border-left: 3px solid var(--success) !important;
        }
        .alert-danger {
            background: var(--danger-dim);
            color: var(--danger);
            border-left: 3px solid var(--danger) !important;
        }

        /* FORM */
        .form-control, .form-select {
            border-radius: 9px;
            border: 1px solid var(--border-em);
            padding: 11px 14px;
            font-size: 0.9rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            background: rgba(255,255,255,0.04);
            color: var(--text-light);
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.18);
            background: rgba(255,255,255,0.06);
            color: var(--text-light);
        }
        .form-control::placeholder { color: var(--text-muted); }
        .form-label {
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 6px;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* FOOTER */
        footer {
            border-top: 1px solid var(--border-color);
            padding: 24px 0;
            color: var(--text-muted);
            font-size: 0.8rem;
            margin-top: 60px;
        }

        /* HERO */
        .hero-icon {
            font-size: 3.5rem;
            color: var(--accent);
            background: var(--primary-glow);
            padding: 18px;
            border-radius: 50%;
            display: inline-block;
        }

        /* STATS */
        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            padding: 20px;
        }
        .stat-number {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--text-light);
            letter-spacing: -0.5px;
        }
        .stat-label {
            color: var(--text-muted);
            font-weight: 600;
            margin-top: 4px;
            text-transform: uppercase;
            font-size: 0.68rem;
            letter-spacing: 0.07em;
        }

        /* TABLE */
        .table { color: var(--text-light); border-color: var(--border-color); }
        .table th {
            background: rgba(255,255,255,0.03);
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.68rem;
            letter-spacing: 0.06em;
            border-bottom: 1px solid var(--border-em) !important;
        }
        .table td { border-color: var(--border-color); vertical-align: middle; }
        .table-hover tbody tr:hover { background: rgba(255,255,255,0.03); }
        code {
            background: rgba(255,255,255,0.06);
            color: var(--accent);
            padding: 2px 8px;
            border-radius: 5px;
            font-size: 0.8rem;
            border: 1px solid var(--border-color);
        }
        hr { border-color: var(--border-color) !important; }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .navbar-brand { font-size: 1.1rem; }
            .balance { font-size: 1.8rem; }
            .card-body { padding: 18px 16px; }
            .btn { padding: 9px 16px; font-size: 0.82rem; }
            .stat-number { font-size: 1.8rem; }
        }
        @media (max-width: 576px) {
            .balance { font-size: 1.5rem; }
            .card { border-radius: 12px !important; }
        }

        /* ANIMATIONS */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .animate           { animation: fadeInUp 0.4s ease both; }
        .animate-delay-1   { animation-delay: 0.08s; }
        .animate-delay-2   { animation-delay: 0.16s; }
        .animate-delay-3   { animation-delay: 0.24s; }

        /* SCROLLBAR */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-dark); }
        ::-webkit-scrollbar-thumb { background: var(--border-em); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--primary); }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <span class="brand-icon"><i class="bi bi-bank2"></i></span>
                BANK<span>SYSTEM</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                style="color:var(--text-muted); filter:invert(0.6);">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/accounts/create"><i class="bi bi-plus-circle"></i> Nouveau compte</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/transfer"><i class="bi bi-arrow-left-right"></i> Virement</a>
                        </li>
                    <% } %>
                </ul>
                <ul class="navbar-nav align-items-center gap-2">
                    <% if (user) { %>
                        <li class="nav-item">
                            <span class="navbar-text">
                                <span class="user-pill">
                                    <span class="user-avatar"><i class="bi bi-person-fill"></i></span>
                                    <%= user.firstName %>
                                </span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/logout"><i class="bi bi-box-arrow-right"></i> Quitter</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login"><i class="bi bi-box-arrow-in-right"></i> Connexion</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm px-3" href="/register">
                                <i class="bi bi-person-plus me-1"></i> Inscription
                            </a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN -->
    <main class="py-4">
        <div class="container">
            <% if (message) { %>
                <div class="alert alert-<%= message.type %> alert-dismissible fade show animate" role="alert">
                    <i class="bi <%= message.icon %> me-2"></i> <%= message.text %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
            <%- body %>
        </div>
    </main>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start text-center">
                    <i class="bi bi-shield-lock-fill me-1" style="color: var(--primary);"></i>
                    <span style="font-weight:700; color: var(--text-light);">BANK<span style="color:var(--accent);">SYSTEM</span></span>
                    <span class="ms-2">&copy; 2026</span>
                </div>
                <div class="col-md-6 text-md-end text-center mt-2 mt-md-0">
                    <span>Secure &bull; Reliable &bull; Fast</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
