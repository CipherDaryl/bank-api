<%- include('layout', { 
  title: 'Retrait',
  user: user,
  message: message
}) %>
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header bg-warning">
        <h4 class="mb-0"><i class="bi bi-dash-circle"></i> Retrait</h4>
      </div>
      <div class="card-body">
        <form action="/withdraw" method="POST">
          <input type="hidden" name="accountId" value="<%= accountId %>">
          <div class="mb-3">
            <label class="form-label">Montant (XAF) *</label>
            <input type="number" name="amount" class="form-control" required placeholder="0" min="1">
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <input type="text" name="description" class="form-control" placeholder="Retrait au guichet">
          </div>
          <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a href="/dashboard" class="btn btn-secondary">Annuler</a>
            <button type="submit" class="btn btn-warning">
              <i class="bi bi-dash-circle"></i> Retirer
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>